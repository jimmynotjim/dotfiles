#!/usr/bin/env bash

set -eo pipefail

CONFIG="install.conf.yaml"

readonly DOTBOT_DIR='dotbot'
readonly DOTBOT_BIN='bin/dotbot'
readonly BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

readonly ARGS="$@"

cd "${BASEDIR}"

# Cache sudo credentials upfront so non-interactive steps (e.g. Homebrew install) don't hang
sudo -v

git submodule sync --quiet --recursive
git submodule update --init --recursive

readonly LOGFILE="$BASEDIR/install.log"
: > "$LOGFILE"

run_dotbot () {
  local config
  config="$1"

  echo "Running $config..." | tee -a "$LOGFILE"
  if ! "$BASEDIR/$DOTBOT_DIR/$DOTBOT_BIN" \
    -d "$BASEDIR" \
    --plugin-dir dotbot-brewfile \
    -c "$config" $ARGS 2>&1 | tee -a "$LOGFILE"; then
    echo "ERROR: $config failed. See $LOGFILE for details." | tee -a "$LOGFILE"
    exit 1
  fi
}

run_dotbot 'steps/macos.yml'
run_dotbot 'steps/homebrew-install.yml'

# Add Homebrew to PATH before installing packages (needed on Apple Silicon)
[[ -f "/opt/homebrew/bin/brew" ]] && eval "$(/opt/homebrew/bin/brew shellenv)"
[[ -f "/usr/local/bin/brew" ]] && eval "$(/usr/local/bin/brew shellenv)"

run_dotbot 'steps/homebrew-packages.yml'
run_dotbot 'steps/iterm.yml'
run_dotbot 'steps/vscode.yml'
run_dotbot 'steps/javascript.yml'
run_dotbot 'steps/complete.yml'
