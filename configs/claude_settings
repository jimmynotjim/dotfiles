{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(paste:*)",
      "Bash(plutil:*)",
      "Bash(swiftlint lint:*)",
      "Bash(xcodebuild:*)",
      "mcp__pencil",
      "mcp__claude_ai_Notion__notion-create-comment",
      "mcp__claude_ai_Notion__notion-update-page"
    ],
    "deny": [],
    "ask": []
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "notion-ea@jimmy-claude-plugins": true,
    "fire-risk-data@jimmy-claude-plugins": true,
    "fire-risk-ea@jimmy-claude-plugins": true,
    "fire-risk-development@jimmy-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "jimmy-claude-plugins": {
      "source": {
        "source": "git",
        "url": "git@github.com:jimmynotjim/claude-plugins.git"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "skipAutoPermissionPrompt": true,
  "defaultMode": "auto",
  "ENABLE_LSP_TOOL": "1",
  "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
}
